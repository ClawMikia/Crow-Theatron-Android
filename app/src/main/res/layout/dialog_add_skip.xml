<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvSkipDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Define Skip Segment"
        android:textColor="@color/crow_on_bg"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold" />

    <!-- START POINT -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSkipStart"
        style="@style/Widget.CrowTheatron.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Start Time (seconds or mm:ss)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSkipStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/crow_on_bg"
            android:fontFamily="@font/orbitron_regular" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- END POINT -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSkipEnd"
        style="@style/Widget.CrowTheatron.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="End Time (seconds or mm:ss)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSkipEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/crow_on_bg"
            android:fontFamily="@font/orbitron_regular" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackground"
            android:text="Cancel"
            android:textColor="@color/crow_on_muted"
            android:fontFamily="@font/orbitron_bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_outline_pink"
            android:text="Save Skip"
            android:textColor="@color/crow_accent_pink"
            android:fontFamily="@font/orbitron_bold" />
    </LinearLayout>

</LinearLayout>
