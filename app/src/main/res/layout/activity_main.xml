<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/crow_bg"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/crow_surface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/app_name" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:text="Local video theater — folders, memory, and playback tuned for you."
                android:textColor="@color/crow_on_muted"
                android:textSize="13sp" />

            <!-- ── Primary action ───────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="start|center_vertical"
                android:text="@string/pick_folder"
                android:textColor="@color/crow_bg"
                app:backgroundTint="@color/crow_accent_yellow"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="14dp"
                app:iconTint="@color/crow_bg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenLibrary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="start|center_vertical"
                android:text="@string/nav_library"
                android:textColor="@color/crow_accent_cyan"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="14dp"
                app:iconTint="@color/crow_accent_cyan"
                app:strokeColor="@color/crow_accent_cyan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaylists"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="start|center_vertical"
                android:text="My Playlists"
                android:textColor="@color/crow_accent_yellow"
                app:icon="@android:drawable/ic_menu_add"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="14dp"
                app:iconTint="@color/crow_accent_yellow"
                app:strokeColor="@color/crow_accent_yellow" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueWatching"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="start|center_vertical"
                android:text="Continue Watching"
                android:textColor="@color/crow_accent_green"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="14dp"
                app:iconTint="@color/crow_accent_green"
                app:strokeColor="@color/crow_accent_green" />

            <!-- ── Reset library ───────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetLibrary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:gravity="start|center_vertical"
                android:text="Reset library &amp; re-select folder"
                android:textColor="@color/crow_accent_red"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="14dp"
                app:iconTint="@color/crow_accent_red"
                app:strokeColor="@color/crow_accent_red" />

            <!-- ── Offline section ─────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="4dp"
                android:text="@string/offline_section"
                android:textColor="@color/crow_accent_yellow"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaybackMemory"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="Playback progress &amp; memory"
                android:textColor="@color/crow_on_bg"
                app:icon="@android:drawable/ic_menu_recent_history"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="18dp"
                app:iconTint="@color/crow_accent_yellow" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="@string/settings_title"
                android:textColor="@color/crow_on_bg"
                app:icon="@android:drawable/ic_menu_preferences"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="18dp"
                app:iconTint="@color/crow_accent_cyan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnhancement"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="@string/enhancement_title"
                android:textColor="@color/crow_on_bg"
                app:icon="@android:drawable/ic_menu_gallery"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="18dp"
                app:iconTint="@color/crow_accent_purple" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/crow_surface"
        android:paddingBottom="0dp"
        app:itemIconTint="@color/crow_accent_yellow"
        app:itemTextColor="@color/crow_on_bg"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/menu_bottom_nav" />

</androidx.constraintlayout.widget.ConstraintLayout>
